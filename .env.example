# ══════════════════════════════════════════════════════════════════
#  VRCd Bot — Environment Secrets Schema
#  Copy this file to `.env` and fill in real values.
#  NEVER commit the real `.env` file.
# ══════════════════════════════════════════════════════════════════

# ── Discord (required) ────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=
# Application (client) ID — used for slash command registration
DISCORD_CLIENT_ID=

# ── Steam Web API (required for .vrstats / .steamstatus extras) ──
# Get one at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# ── Last.fm (required for .fm) ────────────────────────────────────
# Create an API account at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ── OpenWeather (required for .weather) ───────────────────────────
# https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ── remove.bg (optional — .removebg falls back to local filters) ─
REMOVEBG_API_KEY=

# ── GitHub (optional — raises rate limits for .github) ───────────
GITHUB_TOKEN=

# ── Ollama (optional — overrides config.json ai.ollamaBaseUrl) ───
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── Channel backup encryption (required for .backup-channel) ─────
# Any strong passphrase; used to derive an AES-256-GCM key.
BACKUP_SECRET=
